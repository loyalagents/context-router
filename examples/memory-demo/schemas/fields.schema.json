{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.example.test/memory-demo/fields.schema.json",
  "title": "Memory Demo Fields",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "fields"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "inputType", "source", "required"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "inputType": {
            "type": "string",
            "enum": ["text", "email", "textarea", "select"]
          },
          "source": {
            "type": "string",
            "enum": ["mcp-memory", "freeform"]
          },
          "memorySlugs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
