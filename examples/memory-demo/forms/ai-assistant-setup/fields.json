      "inputType": "email",
      "source": "profile",
      "profilePath": "email",
      "required": true
    },
    {
      "id": "company",
      "label": "Organization",
      "inputType": "text",
      "source": "profile",
      "profilePath": "company",
      "required": true
    },
    {
      "id": "title",
      "label": "Role",
      "inputType": "text",
      "source": "profile",
