{
  "schemaVersion": 2,
  "formId": "i-9",
  "fields": [
    {
      "fieldIndex": 0,
      "pdfFieldName": "3 A lawful permanent resident Enter USCIS or ANumber",
      "mode": "fact",
      "factKey": "workAuthorization.uscisANumber",
      "when": {
        "factKey": "workAuthorization.citizenshipStatus",
        "equals": "lawful permanent resident"
      },
      "note": "I-9 lawful permanent resident A-number branch."
    },
    {
      "fieldIndex": 1,
      "pdfFieldName": "Signature of Employee",
      "mode": "skip",
      "reason": "manual_attestation",
      "note": "Employee signature requires explicit action for the current form run."
    },
    {
      "fieldIndex": 2,
      "pdfFieldName": "First Name Given Name",
      "mode": "fact",
      "factKey": "identity.firstName"
    },
    {
      "fieldIndex": 3,
      "pdfFieldName": "Employee Middle Initial (if any)",
      "mode": "fact",
      "factKey": "identity.middleInitial"
    },
    {
      "fieldIndex": 4,
      "pdfFieldName": "Employee Other Last Names Used (if any)",
      "mode": "fact",
      "factKey": "identity.otherLastNames"
    },
    {
      "fieldIndex": 5,
      "pdfFieldName": "Today's Date mmddyyy",
      "mode": "skip",
      "reason": "manual_attestation",
      "note": "Employee signature date is part of the attestation and should not be filled from stored memory."
    },
    {
      "fieldIndex": 6,
      "pdfFieldName": "List B Document 1 Title",
      "mode": "skip",
      "reason": "out_of_scope",
      "note": "Section 2 List B document fields are employer or authorized-representative review fields."
