    },
    {
      "fieldIndex": 8,
      "pdfFieldName": "CB_1",
      "mode": "fact",
      "factKey": "workAuthorization.citizenshipStatus",
      "when": {
        "factKey": "workAuthorization.citizenshipStatus",
        "equals": "U.S. citizen"
      },
      "note": "I-9 citizenship checkbox for U.S. citizen."
    },
    {
      "fieldIndex": 9,
      "pdfFieldName": "CB_2",
      "mode": "fact",
      "factKey": "workAuthorization.citizenshipStatus",
      "when": {
        "factKey": "workAuthorization.citizenshipStatus",
        "equals": "noncitizen national"
      },
      "note": "I-9 citizenship checkbox for noncitizen national."
    },
    {
      "fieldIndex": 10,
      "pdfFieldName": "CB_3",
      "mode": "fact",
      "factKey": "workAuthorization.citizenshipStatus",
      "when": {
        "factKey": "workAuthorization.citizenshipStatus",
        "equals": "lawful permanent resident"
      },
      "note": "I-9 citizenship checkbox for lawful permanent resident."
    },
    {
      "fieldIndex": 11,
      "pdfFieldName": "CB_4",
      "mode": "fact",
      "factKey": "workAuthorization.citizenshipStatus",
      "when": {
        "factKey": "workAuthorization.citizenshipStatus",
        "equals": [
          "alien authorized to work",
          "noncitizen authorized to work",
          "A noncitizen authorized to work"
        ]
      },
      "note": "I-9 citizenship checkbox for alien or noncitizen authorized to work."
    },
    {
      "fieldIndex": 12,
      "pdfFieldName": "CB_Alt",
      "mode": "skip",
