{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.local/examples/eval/schemas/manifest.schema.json",
  "title": "Eval Corpus Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "userId",
    "corpusId",
    "forms",
    "purpose",
    "distribution",
    "intentionallyMissing",
    "documents"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "userId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "corpusId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "forms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["documentCount"],
      "properties": {
        "documentCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "intentionallyMissing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factKey", "forms", "reason", "expectedBehavior"],
        "properties": {
          "factKey": {
            "type": "string"
          },
          "forms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expectedBehavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "category",
          "title",
          "factKeys",
          "detailTier",
          "authority",
          "freshness",
          "expectedUse",
          "template"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "factKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "detailTier": {
            "enum": ["hero", "medium", "brief"]
          },
          "authority": {
            "enum": ["high", "medium", "low", "none"]
          },
          "freshness": {
            "enum": ["current", "stale", "mixed", "unknown"]
          },
          "expectedUse": {
            "enum": ["extract", "corroborate", "guardrail", "ignore"]
          },
          "template": {
            "type": ["string", "null"]
          },
          "note": {
            "type": "string"
          }
        }
      }
    }
  }
}
