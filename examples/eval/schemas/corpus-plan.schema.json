{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.local/examples/eval/schemas/corpus-plan.schema.json",
  "title": "Eval Corpus Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "userId",
    "corpusId",
    "forms",
    "purpose",
    "targetDocumentCount",
    "categoryCounts",
    "challengeTags",
    "intentionallyMissing",
    "documents"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "userId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "corpusId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "forms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "targetDocumentCount": {
      "type": "integer",
      "minimum": 1
    },
    "categoryCounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "identity": { "type": "integer", "minimum": 0 },
        "address-contact": { "type": "integer", "minimum": 0 },
        "hr-onboarding": { "type": "integer", "minimum": 0 },
        "payroll-tax": { "type": "integer", "minimum": 0 },
        "work-authorization": { "type": "integer", "minimum": 0 },
        "employer-context": { "type": "integer", "minimum": 0 },
        "partial-conflicting": { "type": "integer", "minimum": 0 },
        "noise": { "type": "integer", "minimum": 0 }
      }
    },
    "challengeTags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "intentionallyMissing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factKey", "forms", "reason", "expectedBehavior"],
        "properties": {
          "factKey": {
            "type": "string"
          },
          "forms": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expectedBehavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "category",
          "title",
          "outputExtension",
          "factKeys",
          "detailTier",
          "authority",
          "freshness",
          "expectedUse",
          "challengeTags",
          "brief"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "category": {
            "enum": [
              "identity",
              "address-contact",
              "hr-onboarding",
              "payroll-tax",
              "work-authorization",
              "employer-context",
              "partial-conflicting",
              "noise"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "outputExtension": {
            "enum": ["md", "txt", "json", "yaml"]
          },
          "factKeys": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "detailTier": {
            "enum": ["hero", "medium", "brief"]
          },
          "authority": {
            "enum": ["high", "medium", "low", "none"]
          },
          "freshness": {
            "enum": ["current", "stale", "mixed", "unknown"]
          },
          "expectedUse": {
            "enum": ["extract", "corroborate", "guardrail", "ignore"]
          },
          "challengeTags": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
            }
          },
          "brief": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
