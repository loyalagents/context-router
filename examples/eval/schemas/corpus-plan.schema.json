{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.local/examples/eval/schemas/corpus-plan.schema.json",
  "title": "Eval Corpus Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "userId",
    "corpusId",
    "forms",
    "purpose",
    "artifactWorld",
    "factContractDefaults",
    "intentionallyMissing",
    "documents"
  ],
  "properties": {
    "schemaVersion": { "const": 2 },
    "userId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "corpusId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "forms": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "artifactWorld": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schemaVersion", "seed", "timeline"],
      "properties": {
        "schemaVersion": { "const": 1 },
        "seed": {
          "type": "string",
          "minLength": 1
        },
        "timeline": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        }
      }
    },
    "factContractDefaults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["forbid"],
      "properties": {
        "forbid": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string" }
        }
      }
    },
    "intentionallyMissing": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["factKey", "forms", "reason", "expectedBehavior"],
        "properties": {
          "factKey": { "type": "string" },
          "forms": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "expectedBehavior": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "category",
          "title",
          "outputExtension",
          "sourceSpec",
          "factContract",
          "evaluationRole"
        ],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "category": {
            "enum": [
              "identity",
              "address-contact",
              "hr-onboarding",
              "payroll-tax",
              "work-authorization",
              "employer-context",
              "partial-conflicting",
              "noise"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "outputExtension": {
            "enum": ["md", "txt", "json", "yaml"]
          },
          "sourceSpec": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "artifactType",
              "sourceFamily",
              "captureMode",
              "timelineRefs",
              "worldRefs",
              "nativeSignals",
              "safeDetailMenu",
              "riskyDetailMenu",
              "lengthTarget"
            ],
            "properties": {
              "artifactType": { "type": "string", "minLength": 1 },
              "sourceFamily": { "type": "string", "minLength": 1 },
              "captureMode": { "type": "string", "minLength": 1 },
              "timelineRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "worldRefs": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "nativeSignals": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              },
              "safeDetailMenu": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "riskyDetailMenu": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "lengthTarget": {
                "type": "object",
                "additionalProperties": false,
                "required": ["minChars", "maxChars"],
                "properties": {
                  "minChars": { "type": "integer", "minimum": 1 },
                  "maxChars": { "type": "integer", "minimum": 1 }
                }
              }
            }
          },
          "factContract": {
            "type": "object",
            "additionalProperties": false,
            "required": ["include", "forbid"],
            "properties": {
              "include": {
                "type": "array",
                "items": { "type": "string" }
              },
              "forbid": {
                "type": "array",
                "uniqueItems": true,
                "items": { "type": "string" }
              }
            }
          },
          "evaluationRole": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "detailTier",
              "authority",
              "freshness",
              "expectedUse",
              "challengeTags"
            ],
            "properties": {
              "detailTier": { "enum": ["hero", "medium", "brief"] },
              "authority": { "enum": ["high", "medium", "low", "none"] },
              "freshness": { "enum": ["current", "stale", "mixed", "unknown"] },
              "expectedUse": {
                "enum": ["extract", "corroborate", "guardrail", "ignore"]
              },
              "challengeTags": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
                }
              }
            }
          }
        }
      }
    }
  }
}
