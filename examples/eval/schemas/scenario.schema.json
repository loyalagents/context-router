{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.local/examples/eval/schemas/scenario.schema.json",
  "title": "Eval Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "scenarioId", "userId", "corpusId", "formId"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "scenarioId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "userId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "corpusId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "formId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "string"
    },
    "expectedSnapshots": {
      "type": "array",
      "items": {
        "enum": ["filled-form", "written-preferences", "final-preferences"]
      }
    }
  }
}
