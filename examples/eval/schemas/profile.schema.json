{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://context-router.local/examples/eval/schemas/profile.schema.json",
  "title": "Eval Synthetic User Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "userId", "displayName", "facts"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "userId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "displayName": {
      "type": "string",
      "minLength": 1
    },
    "facts": {
      "type": "object",
      "description": "Authoritative local fixture facts. Nested paths form canonical fact keys; null declares an intentionally absent or user-inapplicable fact.",
      "additionalProperties": true
    },
    "seedPreferences": {
      "type": "array",
      "description": "Optional known-schema seed bridge. Open-schema packet fixtures can omit this and rely on corpus evidence instead.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slug", "factKey"],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*(?:\\.[a-z][a-z0-9_]*)+$"
          },
          "factKey": {
            "type": "string",
            "pattern": "^[a-z][A-Za-z0-9]*(?:\\.[a-z][A-Za-z0-9]*)+$"
          }
        }
      }
    }
  }
}
