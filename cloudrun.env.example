# Cloud Run runtime config. Copy to cloudrun.env for local deploys.
# TODO: Move DATABASE_URL and AUTH0_CLIENT_SECRET to Secret Manager.
# For now, cloudrun.env is ignored by git and can hold the current hosted values.

NODE_ENV=production
GRAPHQL_PLAYGROUND=false
GRAPHQL_DEBUG=false

AUTH0_DOMAIN=<auth0-tenant>.auth0.com
AUTH0_AUDIENCE=https://context-router-api
AUTH0_ISSUER=https://<auth0-tenant>.auth0.com/
AUTH0_CLIENT_ID=<auth0-backend-client-id>
AUTH0_CLIENT_SECRET=<auth0-client-secret>
AUTH0_MANAGEMENT_API_AUDIENCE=https://<auth0-tenant>.auth0.com/api/v2/
AUTH0_SYNC_STRATEGY=ON_LOGIN

CORS_ORIGIN=https://<frontend-host>

DATABASE_URL=postgresql://<db-user>:<db-password>@localhost/<db-name>?schema=public&host=/cloudsql/<project-id>:<region>:<cloud-sql-instance>

GCP_PROJECT_ID=<gcp-project-id>
VERTEX_REGION=us-central1
VERTEX_MODEL_ID=gemini-2.5-flash-lite

MCP_SERVER_URL=https://<cloud-run-service-url>
MCP_OAUTH_REGISTER_RATE_LIMIT=30
AUTH0_MCP_CLAUDE_CLIENT_ID=<auth0-claude-mcp-client-id>
AUTH0_MCP_CODEX_CLIENT_ID=<auth0-codex-mcp-client-id>
AUTH0_MCP_FALLBACK_CLIENT_ID=<auth0-fallback-mcp-client-id>
AUTH0_MCP_PUBLIC_CLIENT_ID=<auth0-public-mcp-client-id>
